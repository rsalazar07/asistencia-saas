# ==========================================================================
# Variables de Entorno - Backend
# ==========================================================================

# ─── SERVER ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ─── BASE DE DATOS ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/asistencia_saas?schema=public"

# ─── JWT ────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=super-secret-access-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production-min-32-chars
JWT_REFRESH_EXPIRES=7d
BCRYPT_SALT_ROUNDS=12
MAX_SESSIONS_PER_USER=5

# ─── REDIS ──────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=300

# ─── CORS ───────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ─── STORAGE ────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=asistencia-saas
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
